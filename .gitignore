# ========== GENERATED/CACHE FILES (DO NOT COMMIT) ==========
ERRORS
# Python virtual environment (machine-specific, can be recreated with requirements.txt)
venv/

# Python cache (auto-generated bytecode)
__pycache__/
*.pyc
*.pyo

# Spark/Ivy cache (auto-downloaded JARs, ~100MB+)
# These are downloaded automatically on first run via spark.jars.packages
.ivy2/

# Spark temporary checkpoint locations
/tmp/temporary-*/

# Environment files (may contain secrets like passwords, API keys)
.env

# IDE/editor specific files
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# ========== FILES THAT SHOULD BE COMMITTED ==========
# producer_orders.py       (source code)
# spark_consumer.py        (source code)
# docker-compose.yml       (infrastructure config)
# requirements.txt         (dependency list)
# .gitignore               (this file)
# ERRORS.md                (documentation)
